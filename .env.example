# Discord Application (from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Plex Media Server
PLEX_URL=http://localhost:32400
PLEX_TOKEN=

# Optional — plex.tv ACCOUNT token, used only for online "Discover" search detail
# lookups (movies/shows not in your library). The server PLEX_TOKEN above is a
# *server* token that the Plex cloud provider rejects, so without this, Discover
# results show but their detail pages have no description. Grab it from an
# app.plex.tv network request (the X-Plex-Token query param). Falls back to
# PLEX_TOKEN if unset.
PLEX_ACCOUNT_TOKEN=

# Server
PORT=3000

# Your public URL — must match the URL mapping in Discord Developer Portal
REDIRECT_URI=https://your-domain.example.com
ALLOWED_ORIGINS=https://your-domain.example.com

# Optional — restrict to specific Discord server(s), comma-separated
# Leave empty to allow all servers
ALLOWED_GUILD_IDS=

# Optional — admin secret for /api/plex/hls/sessions endpoint
ADMIN_SECRET=

# Optional — VPS relay for watch party segment delivery.
# When set, HLS segments route through the VPS instead of this server.
# Also disables P2P (VPS bandwidth makes it unnecessary).
# See docs/vps-relay-setup.md for full setup guide.
# VPS_RELAY_URL=https://theater.yourdomain.com
# VPS_RELAY_KEY=

# Optional — transcode bitrate tuning (kbps).
# Per-viewer bandwidth scales with this — lower it if home upload is tight,
# raise it for higher quality (VIDEO_BITRATE_KBPS is the average target,
# VIDEO_PEAK_BITRATE_KBPS bounds spikes).
# VIDEO_BITRATE_KBPS=12000
# VIDEO_PEAK_BITRATE_KBPS=20000

# Optional — thumbnail cache tuning
# THUMB_CACHE_TTL_MS=604800000
# THUMB_CACHE_MAX_MB=500

# Optional — Seerr (Overseerr / Jellyseerr) integration for requesting titles
# that aren't in your library, from the Discover detail page. Set both to enable
# the Request button; leave unset to hide it. Get the API key from Seerr's
# Settings → General.
# SEERR_URL=https://requests.yourdomain.com
# SEERR_API_KEY=
